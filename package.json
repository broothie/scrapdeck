{
  "name": "plumboard",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @plumboard/web run dev",
    "build": "npm --workspace @plumboard/web run build",
    "preview": "npm --workspace @plumboard/web run preview",
    "test": "npm --workspace @plumboard/web run test",
    "db:types": "sh -c 'tmp=\"$(mktemp -t plumboard-database-types)\" && supabase gen types --lang=typescript --linked --schema public > \"$tmp\" && mv \"$tmp\" packages/core/src/database.types.ts'"
  },
  "devDependencies": {
    "supabase": "^2.48.3"
  }
}
